# SecureVoteChain Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to GitHub!

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Encryption Keys (Generate with: python -c "import secrets; print(secrets.token_hex(32))")
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=False

# SMS OTP Configuration
# SMS sent via Supabase Phone Auth (no additional config needed here)
# Configure Twilio credentials in: Supabase Dashboard → Authentication → Providers → Phone

# Security Settings
OTP_EXPIRY_MINUTES=5
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
